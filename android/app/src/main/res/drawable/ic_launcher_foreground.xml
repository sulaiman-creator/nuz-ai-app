<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- 1. Left Pillar: Google Blue transitioning to Google Red (vertical) -->
    <path
        android:pathData="M6,6 L8.5,6 L8.5,18 L6,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="7.25"
                android:startY="6"
                android:endX="7.25"
                android:endY="18">
                <item android:offset="0.0" android:color="#4285F4" />
                <item android:offset="1.0" android:color="#EA4335" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 2. Right Pillar: Google Green transitioning to Google Blue (vertical) -->
    <path
        android:pathData="M15.5,6 L18,6 L18,18 L15.5,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="16.75"
                android:startY="18"
                android:endX="16.75"
                android:endY="6">
                <item android:offset="0.0" android:color="#34A853" />
                <item android:offset="1.0" android:color="#4285F4" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 3. Upper Diagonal: Google Red transitioning to Google Yellow -->
    <path
        android:pathData="M6,6 L8.5,6 L13.25,12 L10.75,12 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="6"
                android:startY="6"
                android:endX="13.25"
                android:endY="12">
                <item android:offset="0.0" android:color="#EA4335" />
                <item android:offset="1.0" android:color="#FBBC05" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 4. Lower Diagonal: Google Yellow transitioning to Google Green -->
    <path
        android:pathData="M10.75,12 L13.25,12 L18,18 L15.5,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="10.75"
                android:startY="12"
                android:endX="18"
                android:endY="18">
                <item android:offset="0.0" android:color="#FBBC05" />
                <item android:offset="1.0" android:color="#34A853" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 5. Left Fold Drop Shadow (Simulating diagonal overlapping left pillar) -->
    <path
        android:pathData="M8.5,6 L9.5,6.8 L9.5,10.2 L8.5,9.4 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="8.5"
                android:startY="8.1"
                android:endX="9.5"
                android:endY="8.1">
                <item android:offset="0.0" android:color="#3A000000" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 6. Right Fold Drop Shadow (Simulating right pillar overlapping lower diagonal) -->
    <path
        android:pathData="M15.5,13.8 L16.3,14.4 L16.3,18 L15.5,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="15.5"
                android:startY="15.9"
                android:endX="16.3"
                android:endY="15.9">
                <item android:offset="0.0" android:color="#30000000" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 7. Center Fold Gradient Shadow (Adds rich ribbon fold definition in center) -->
    <path
        android:pathData="M10.75,12 L13.25,12 L12.6,13.5 L11.4,13.5 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="12"
                android:startY="12"
                android:endX="12"
                android:endY="13.5">
                <item android:offset="0.0" android:color="#25000000" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
